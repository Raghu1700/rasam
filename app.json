{
  "expo": {
    "name": "Rasam",
    "slug": "rasam",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "rasam",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B81"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.raghu.rasam",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.raghu.rasam",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B81"
      },
      "permissions": [
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF6B81"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Rasam needs access to your photos to share your Photo of the Day."
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "StatusWidget",
              "label": "Rasam — Partner Status",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "description": "See your partner's status and send a heartbeat",
              "previewImage": "./assets/widget-preview.png",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "d4a56518-1f20-4e28-a8ce-de4b3f227210"
      }
    },
    "owner": "raghu1700"
  }
}
