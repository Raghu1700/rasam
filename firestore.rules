rules_version = '2';

// Rasam security rules. A user may only touch the couple document they are a
// member of, and its subcollections. Anonymous auth is required.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isMember(coupleData) {
      return signedIn() && request.auth.uid in coupleData.members;
    }

    match /couples/{coupleId} {
      // Read if you're a member. We allow broad read on create/join because a
      // joiner must look the couple up by code before they are a member yet.
      // (Codes are random 6-char; for stricter setups use a Cloud Function.)
      allow read: if signedIn();

      // Create: must put yourself in members.
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.members;

      // Update: existing members, OR a new user joining (adds only themselves
      // and the couple isn't already full).
      allow update: if isMember(resource.data)
        || (signedIn()
            && resource.data.members.size() < 2
            && request.resource.data.members.hasAll(resource.data.members)
            && request.auth.uid in request.resource.data.members);

      allow delete: if isMember(resource.data);

      // Member docs (status, push token, name).
      match /members/{memberId} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
        allow write: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
      }

      // Photo of the Day (stored as a compressed base64 image in Firestore).
      match /photoOfDay/{docId} {
        allow read, write: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
      }

      // Signals (alerts, replies, heartbeats).
      match /signals/{signalId} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
        allow create: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members
          && request.resource.data.from == request.auth.uid;
        allow update, delete: if false;
      }
    }
  }
}
